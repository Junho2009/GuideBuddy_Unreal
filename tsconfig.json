{
  "compilerOptions": {
    "target": "ES2018",
    "module": "CommonJS",
    "rootDir": "TypeScript",
    "outDir": "Content/JavaScript",
    "strict": true,
    "noImplicitAny": true,
    "esModuleInterop": false,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true
  },
  "include": [
    "TypeScript/**/*.ts"
  ]
}
